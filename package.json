{
  "name": "toolhutch",
  "version": "0.1.0",
  "description": "Local-first permission auditor for agent tool manifests.",
  "type": "module",
  "bin": {
    "toolhutch": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "examples",
    "fixtures",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test \"tests/**/*.test.js\"",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run check && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-tools",
    "mcp",
    "security",
    "permissions",
    "cli",
    "local-first"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
